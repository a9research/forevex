# Local Postgres (see docker-compose: host port 5433)
DATABASE_URL=postgres://forevex:forevex@127.0.0.1:5433/forevex

# Optional aliases
# FOREVEX_DATABASE_URL=...

# HTTP
FOREVEX_BIND=0.0.0.0:8080
FOREVEX_PUBLIC_BASE_URL=http://localhost:8088

# Upstream (override if needed)
# FOREVEX_GAMMA_ORIGIN=https://gamma-api.polymarket.com
# FOREVEX_DATA_API_ORIGIN=https://data-api.polymarket.com
# FOREVEX_USER_STATS_URL=https://data-api.polymarket.com/v1/user-stats
# FOREVEX_USER_PNL_URL=https://user-pnl-api.polymarket.com/user-pnl

FOREVEX_HTTP_TIMEOUT_SEC=45
FOREVEX_RATE_LIMIT_MS=120
RUST_LOG=info,sqlx=warn
