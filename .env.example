# PostgreSQL（必填）
#
# 本地开发：只用 Docker 跑 Postgres 时（见 README「本地开发」），compose 把库映射到 127.0.0.1:5433，
# 用户/密码/库名与 docker-compose.yml 中 postgres 服务一致：
# DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5433/polymarket_pipeline
#
# 本机直连其它 Postgres 时自行改写端口/库名：
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5433/polymarket_pipeline

# sqlx 连接池（大 CSV 导入时建议 ≥16；须小于 Postgres max_connections 减去其它客户端）
# PIPELINE_DB_MAX_CONNECTIONS=16
# 池子满时等待空闲连接的最长时间（秒）
# PIPELINE_DB_ACQUIRE_TIMEOUT_SEC=120

# Gamma / Data API 基址（sync 等会用到；代码里已有上列默认值，一般不必写）
# 仅在使用镜像、代理或非官方地址时取消注释并修改：
# PIPELINE_GAMMA_ORIGIN=https://gamma-api.polymarket.com
# PIPELINE_DATA_API_ORIGIN=https://data-api.polymarket.com

# PIPELINE_MARKETS_BATCH_SIZE=500
# PIPELINE_HTTP_TIMEOUT_SEC=120
# PIPELINE_RATE_LIMIT_MS=120

# 逗号分隔 0x 地址 — ingest-activities
# PIPELINE_ACTIVITY_PROXIES=0xabc...,0xdef...

# 快照白名单（空则取 dim_wallets 最近 PIPELINE_SNAPSHOT_MAX_WALLETS 个）
# PIPELINE_SNAPSHOT_PROXIES=
# PIPELINE_SNAPSHOT_MAX_WALLETS=200

# PIPELINE_USER_STATS_URL=https://data-api.polymarket.com/v1/user-stats
# PIPELINE_USER_PNL_URL=https://user-pnl-api.polymarket.com/user-pnl
# PIPELINE_GAMMA_PUBLIC_PROFILE_URL=https://gamma-api.polymarket.com/public-profile

# polymarket-pipeline serve
# PIPELINE_HTTP_BIND=0.0.0.0:8080

# —— PMA：本地目录仅作解压/增量暂存；生产须配对象存储 ——
# PIPELINE_PMA_DATA_DIR=data
# 未配置 OSS bucket 时允许仅从本地 Parquet 入库（仅开发）
# PIPELINE_PMA_ALLOW_LOCAL_ONLY=1
# bootstrap-data 默认下载 data.tar.zst
# PIPELINE_BOOTSTRAP_DOWNLOAD_URL=https://s3.jbecker.dev/data.tar.zst

# —— 阿里云 OSS（S3 兼容 API）或通用 S3 ——
# 二选一填写 bucket：PIPELINE_OSS_BUCKET 或 PIPELINE_S3_BUCKET
# PIPELINE_OSS_BUCKET=your-bucket
# Region，如 oss-cn-hangzhou
# PIPELINE_OSS_REGION=oss-cn-hangzhou
# Endpoint，须为绝对 URL（推荐带 https://）；仅填主机名时会自动补 https://
# PIPELINE_OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
# 与控制台 AccessKey 一致（也可用 PIPELINE_S3_* 别名）
# PIPELINE_OSS_ACCESS_KEY_ID=
# PIPELINE_OSS_ACCESS_KEY_SECRET=
# 虚拟主机域名访问（部分 OSS 场景需开启）
# PIPELINE_OSS_VIRTUAL_HOSTED=0
# 对象键前缀，如 prod → prod/polymarket/trades/...
# PIPELINE_S3_PREFIX=

# 日志
# RUST_LOG=info,polymarket_pipeline=debug
